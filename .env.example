# Vision provider. Currently only "anthropic" is implemented — it speaks the
# Anthropic Messages API and works with the official endpoint OR any
# compatible proxy (e.g. a domestic-model gateway).
VISION_PROVIDER=anthropic

# Required. Get one at https://console.anthropic.com/ for the official API,
# or use whatever key your proxy issues.
ANTHROPIC_API_KEY=

# Required. The model name the endpoint serves.
#   - Official API:  claude-sonnet-4-6
#   - 国内代理:        whatever string your proxy expects
# Note: ANTHROPIC_MODEL / ANTHROPIC_API_KEY are read from the process
# environment. If your shell already exports ANTHROPIC_MODEL for other
# tooling, copy that value into this .env to make screen-mcp's model
# choice explicit.
ANTHROPIC_MODEL=

# Optional. Points the SDK at an Anthropic-Messages-compatible proxy.
# Leave blank to use the official Anthropic API.
#   国内代理示例: https://api.minimaxi.com/anthropic
ANTHROPIC_BASE_URL=

# Sampling cadence for polling mode (seconds between frames).
DEFAULT_POLLING_INTERVAL=3.0

# Frame buffer size — how many recent frames we keep in memory at once.
MAX_FRAME_BUFFER=20

# Perceptual hash dedupe: drop a new frame if hamming distance to any of the
# last PHASH_DEDUPE_LOOKBACK frames is below this threshold.
PHASH_DEDUPE_THRESHOLD=6
PHASH_DEDUPE_LOOKBACK=3

# WebP compression for stored frames (1-100). 75 is a good size/quality balance.
WEBP_QUALITY=75

# Max long-edge (px) for frames sent to the vision API. Anthropic recommends <=1564.
CAPTURE_MAX_EDGE=1564
